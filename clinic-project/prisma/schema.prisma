generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"] // این خط را اضافه کنید
}


datasource db {
  provider = "postgresql"
  // خط url را حذف کنید، چون دیگر در اینجا استفاده نمی‌شود
}

// جدول نوبت‌ها
model Appointment {
  id          Int      @id @default(autoincrement())
  patientName String   @map("patient_name")
  patientPhone String  @map("patient_phone")
  day         String
  time        String
  description String?
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")
  smsSent     Boolean  @default(false) @map("sms_sent")

  @@map("appointments")
}

// جدول ذخیره مکالمات چت (برای نگهداری تاریخچه)
model ChatMessage {
  id        Int      @id @default(autoincrement())
  sessionId String   @map("session_id") // برای هر بازدیدکننده یک id
  userMsg   String   @map("user_message")
  botMsg    String   @map("bot_message")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("chat_messages")
}

// جدول دانش (Knowledge Base) برای RAG
model Knowledge {
  id        Int      @id @default(autoincrement())
  question  String   // سوال احتمالی کاربر
  answer    String   // پاسخ استاندارد
  embedding Unsupported("vector")? // اینجا بردار 1536 بعدی ذخیره می‌شود (برای OpenAI)
  category  String?  // دسته‌بندی: خدمات, ساعت کاری, بیمه, ...
  createdAt DateTime @default(now()) @map("created_at")

  @@map("knowledge")
}